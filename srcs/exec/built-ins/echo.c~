#include "../../../includes/minishell.h"


static bool check_option_n(char *line);





static bool check_option_n(char *line)
{
    int i;

    if (!line || line[0] != '-' || line[1] == '\0')
        return (false);
    i = 1;
    while (line[i])
    {
        if (line[i] != 'n')
            return (false);
        i++;
    }
    return (true);
}
